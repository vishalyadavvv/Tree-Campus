# API Configuration
# IMPORTANT: These environment variables are REQUIRED for the application to work
# Copy this file to .env and fill in the actual values

# Backend API URL (without /api suffix)
# Example for local development: http://localhost:4000
# Example for production: https://your-backend-url.com
VITE_API_ORIGIN=

# Backend API URL (with /api suffix)
# Example for local development: http://localhost:4000/api
# Example for production: https://your-backend-url.com/api
VITE_API_URL=
